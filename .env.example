# Shared secret between web proxy and worker
WORKER_TOKEN=change-me-to-a-strong-random-token-min-32-chars

# Initial admin credentials (only used on first startup when DB is empty)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-min-12-chars

# WebAuthn RP ID (set to your domain in production, localhost for dev)
WEBAUTHN_RP_ID=localhost
